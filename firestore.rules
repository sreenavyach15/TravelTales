rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function roomDoc(roomId) {
      return get(/databases/$(database)/documents/chatRooms/$(roomId));
    }

    function isRoomMember(roomId) {
      return signedIn()
        && exists(/databases/$(database)/documents/chatRooms/$(roomId))
        && request.auth.uid in roomDoc(roomId).data.memberUids;
    }

    function isFormerRoomMember(roomId) {
      return signedIn()
        && exists(/databases/$(database)/documents/chatRooms/$(roomId))
        && (
          (
            'removedMemberUids' in roomDoc(roomId).data
            && request.auth.uid in roomDoc(roomId).data.removedMemberUids
          )
          || (
            'leftMemberUids' in roomDoc(roomId).data
            && request.auth.uid in roomDoc(roomId).data.leftMemberUids
          )
        );
    }

    function hasPendingInviteForRoom(roomId) {
      return signedIn()
        && exists(/databases/$(database)/documents/chatInvites/$(roomId + "_" + request.auth.uid))
        && get(/databases/$(database)/documents/chatInvites/$(roomId + "_" + request.auth.uid)).data.status == "pending"
        && get(/databases/$(database)/documents/chatInvites/$(roomId + "_" + request.auth.uid)).data.inviteeUid == request.auth.uid;
    }

    match /users/{uid} {
      // Needed for invite lookup by email and profile display in group features.
      allow read: if signedIn();
      allow create, update, delete: if isSelf(uid);
    }

    match /trips/{tripId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    match /chatRooms/{roomId} {
      allow read: if signedIn() && (
        request.auth.uid in resource.data.memberUids
        || (
          'removedMemberUids' in resource.data
          && request.auth.uid in resource.data.removedMemberUids
        )
        || (
          'leftMemberUids' in resource.data
          && request.auth.uid in resource.data.leftMemberUids
        )
      );
      allow create: if signedIn()
        && request.resource.data.adminUid == request.auth.uid
        && (request.auth.uid in request.resource.data.memberUids);
      allow update: if signedIn() && (
        (request.auth.uid in resource.data.memberUids)
        || (
          isFormerRoomMember(roomId)
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(["hiddenForUids", "updatedAt"])
        )
        || (
          hasPendingInviteForRoom(roomId)
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            "memberUids",
            "memberEmails",
            "removedMemberUids",
            "removedMemberEmails",
            "leftMemberUids",
            "leftMemberEmails",
            "hiddenForUids",
            "lastReadBy",
            "updatedAt"
          ])
        )
      );
      allow delete: if signedIn() && (request.auth.uid in resource.data.memberUids);

      match /messages/{messageId} {
        allow read: if isRoomMember(roomId);
        allow create: if isRoomMember(roomId) && request.resource.data.authorUid == request.auth.uid;
        allow update, delete: if false;
      }
    }

    match /chatInvites/{inviteId} {
      allow read: if signedIn()
        && (resource.data.inviteeUid == request.auth.uid || resource.data.inviterUid == request.auth.uid);
      allow create: if signedIn() && request.resource.data.inviterUid == request.auth.uid;
      allow update: if signedIn()
        && (resource.data.inviteeUid == request.auth.uid || resource.data.inviterUid == request.auth.uid);
      allow delete: if signedIn() && resource.data.inviterUid == request.auth.uid;
    }

    match /travelDiaryEntries/{entryId} {
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    match /expenses/{expenseId} {
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && (
          !('tripMemberUids' in request.resource.data)
          || request.auth.uid in request.resource.data.tripMemberUids
        );
      allow read: if signedIn()
        && (
          resource.data.userId == request.auth.uid
          || (
            'tripMemberUids' in resource.data
            && request.auth.uid in resource.data.tripMemberUids
          )
        );
      allow update: if signedIn()
        && (
          resource.data.userId == request.auth.uid
          || (
            'tripMemberUids' in resource.data
            && request.auth.uid in resource.data.tripMemberUids
            && request.resource.data.diff(resource.data).changedKeys().hasOnly(["settled", "settledAt", "settlementId", "updatedAt"])
          )
        );
      allow delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    match /expenseSettlements/{settlementId} {
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && (
          !('tripMemberUids' in request.resource.data)
          || request.auth.uid in request.resource.data.tripMemberUids
        );
      allow read: if signedIn()
        && (
          resource.data.userId == request.auth.uid
          || (
            'tripMemberUids' in resource.data
            && request.auth.uid in resource.data.tripMemberUids
          )
        );
      allow update, delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    match /tripPhotos/{photoId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.uploadedByUid == request.auth.uid;
      allow delete: if signedIn()
        && (
          resource.data.uploadedByUid == request.auth.uid
          || get(/databases/$(database)/documents/trips/$(resource.data.tripId)).data.userId == request.auth.uid
        );
      allow update: if false;
    }

    match /tripNotifications/{notificationId} {
      allow create: if signedIn() && request.resource.data.triggeredByUid == request.auth.uid;
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow update: if signedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(["isRead", "updatedAt"]);
      allow delete: if false;
    }
  }
}
